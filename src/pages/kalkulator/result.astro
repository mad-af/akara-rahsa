---
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---
<div class="kh-step active">
  <h2 class="kh-step-title">Estimasi Budget Kamu</h2>

  <div class="kh-result" id="result-breakdown">
    <div class="kh-result-items">
      <div class="kh-result-item"><span class="kh-result-label">Acara</span><span class="kh-result-value" id="r-acara">-</span></div>
      <div class="kh-result-item"><span class="kh-result-label">Durasi</span><span class="kh-result-value" id="r-hari">-</span></div>
      <div class="kh-result-item"><span class="kh-result-label">Coverage</span><span class="kh-result-value" id="r-coverage">-</span></div>
      <div class="kh-result-item"><span class="kh-result-label">Tambahan</span><span class="kh-result-value" id="r-addons">-</span></div>
      <div class="kh-result-item"><span class="kh-result-label">Lokasi</span><span class="kh-result-value" id="r-lokasi">-</span></div>
    </div>

    <div class="kh-result-total">
      <p class="kh-result-estimate-label">Estimasi Harga</p>
      <p class="kh-result-estimate" id="r-price">Rp -</p>
    </div>

    <p class="kh-result-note">Ini baru estimasi. Paket final bisa disesuaikan dengan budget kamu. Hubungi kami untuk konsultasi gratis.</p>
  </div>

  <div class="kh-lead">
    <h3 style="font-family: var(--font-display); font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">Dapatkan Detail Paket</h3>
    <p style="font-size: 0.875rem; color: var(--ink-secondary, #666); margin-bottom: 1.25rem;">Isi nama dan nomor WA kamu, kami kirimkan detail paket lengkapnya.</p>
    <div class="kh-lead-form">
      <input type="text" id="lead-nama" placeholder="Nama kamu" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid rgba(0,0,0,0.1); background: var(--ground, #fff); font-family: var(--font-body); font-size: 0.9375rem; outline: none; box-sizing:border-box;">
      <input type="tel" id="lead-wa" placeholder="Nomor WhatsApp (contoh: 628123456789)" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid rgba(0,0,0,0.1); background: var(--ground, #fff); font-family: var(--font-body); font-size: 0.9375rem; outline: none; box-sizing:border-box;">
      <button id="btn-kirim-wa" class="btn-primary" disabled>Kirim ke WhatsApp</button>
    </div>
    <p style="font-size: 0.75rem; color: var(--ink-secondary, #999); margin-top: 0.75rem;">Kamu akan diarahkan ke WhatsApp untuk melanjutkan diskusi.</p>
  </div>

  <div class="kh-nav">
    <button class="btn-secondary"
      hx-get={BASE + "kalkulator/step-5"}
      hx-target="#step-container"
      hx-swap="innerHTML">Hitung Ulang</button>
  </div>
</div>

<script is:inline>
(function() {
  function readState() {
    return {
      acara: sessionStorage.getItem('kal_acara'),
      hari: sessionStorage.getItem('kal_hari'),
      coverage: sessionStorage.getItem('kal_coverage'),
      addons: JSON.parse(sessionStorage.getItem('kal_addons') || '{}'),
      lokasi: sessionStorage.getItem('kal_lokasi'),
      jarak: sessionStorage.getItem('kal_jarak') || ''
    };
  }

  var s = readState();
  var r = calculatePricing(s);
  var labels = window.labels;

  function getLabel(group, val) {
    return (labels[group] && labels[group][val]) || '-';
  }

  document.getElementById('r-acara').textContent = getLabel('acara', s.acara);
  document.getElementById('r-hari').textContent = getLabel('hari', s.hari);
  document.getElementById('r-coverage').textContent = getLabel('coverage', s.coverage);

  var addonList = [];
  for (var k in s.addons) {
    if (s.addons[k]) addonList.push(getLabel('addons', k));
  }
  document.getElementById('r-addons').textContent = addonList.length ? addonList.join(', ') : '-';
  document.getElementById('r-lokasi').textContent = getLabel('lokasi', s.lokasi);
  document.getElementById('r-price').textContent = formatIDR(r.min) + ' – ' + formatIDR(r.max);

  document.getElementById('result-breakdown').scrollIntoView({ behavior: 'smooth', block: 'start' });

  var nama = document.getElementById('lead-nama');
  var wa = document.getElementById('lead-wa');
  var kirim = document.getElementById('btn-kirim-wa');

  function validateLead() {
    var n = nama.value.trim();
    var w = wa.value.trim();
    if (n.length >= 2 && w.length >= 8 && (w.startsWith('0') || w.startsWith('62'))) {
      kirim.removeAttribute('disabled');
    } else {
      kirim.setAttribute('disabled', 'disabled');
    }
  }

  nama.addEventListener('input', validateLead);
  wa.addEventListener('input', validateLead);

  kirim.addEventListener('click', function() {
    var n = nama.value.trim();
    var w = wa.value.trim();
    if (!n || !w) return;

    var msg = 'Halo kak! Saya ' + n + ', tertarik dokumentasi pernikahan.\n\n';
    msg += 'Hasil estimasi saya:\n';
    msg += '- Acara: ' + getLabel('acara', s.acara) + '\n';
    msg += '- Durasi: ' + getLabel('hari', s.hari) + '\n';
    msg += '- Coverage: ' + getLabel('coverage', s.coverage) + '\n';
    if (addonList.length) msg += '- Tambahan: ' + addonList.join(', ') + '\n';
    msg += '- Estimasi: ' + formatIDR(r.min) + ' - ' + formatIDR(r.max) + '\n\n';
    msg += 'Bisa minta info detail paketnya? Terima kasih!';

    var waNum = w.replace(/[^0-9]/g, '');
    if (waNum.startsWith('0')) waNum = '62' + waNum.slice(1);
    window.open('https://wa.me/' + waNum + '?text=' + encodeURIComponent(msg), '_blank');
  });
})();
</script>
