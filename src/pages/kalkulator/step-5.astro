---
const BASE = import.meta.env.BASE_URL.replace(/\/?$/, "/");
---
<div class="kh-step active">
  <h2 class="kh-step-title">Lokasi Venue</h2>
  <p class="kh-step-desc">Di mana lokasi acara kamu?</p>
  <div class="kh-options" id="step5-options">
    <button class="kh-opt" data-value="dalamKota">
      <span class="kh-opt-label">Dalam Kota Kediri</span>
      <span class="kh-opt-desc">Tanpa biaya transportasi tambahan</span>
      <span class="kh-opt-price">Biaya — (gratis)</span>
    </button>
    <button class="kh-opt" data-value="luarKota">
      <span class="kh-opt-label">Luar Kota Kediri</span>
      <span class="kh-opt-desc">Ada tambahan biaya transportasi</span>
      <span class="kh-opt-price">Biaya + Rp 300.000</span>
    </button>
  </div>
  <div id="jarak-container" style="display:none; margin-top: 1rem;">
    <label for="jarak" style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem;">Jarak dari Kediri (km)</label>
    <input type="number" id="jarak" min="0" placeholder="Contoh: 50" style="width: 100%; padding: 0.75rem 1rem; border: 1px solid rgba(0,0,0,0.1); background: var(--ground, #fff); font-family: var(--font-body); font-size: 1rem; outline: none; box-sizing:border-box;">
  </div>
  <div class="kh-nav">
    <button class="btn-secondary"
      hx-get={BASE + "kalkulator/step-4"}
      hx-target="#step-container"
      hx-swap="innerHTML">Kembali</button>
    <button class="btn-primary kh-next"
      hx-get={BASE + "kalkulator/result"}
      hx-target="#step-container"
      hx-swap="innerHTML"
      disabled>Lihat Estimasi</button>
  </div>
</div>

<script is:inline>
(function() {
  var saved = sessionStorage.getItem('kal_lokasi');
  var savedJarak = sessionStorage.getItem('kal_jarak') || '';
  var nextBtn = document.querySelector('.kh-next');
  var options = document.getElementById('step5-options');
  var jarakContainer = document.getElementById('jarak-container');
  var jarakInput = document.getElementById('jarak');

  if (saved) {
    var sel = options.querySelector('[data-value="' + saved + '"]');
    if (sel) {
      sel.classList.add('selected');
      nextBtn.removeAttribute('disabled');
      if (saved === 'luarKota') jarakContainer.style.display = 'block';
    }
  }
  if (savedJarak && jarakInput) jarakInput.value = savedJarak;

  options.addEventListener('click', function(e) {
    var btn = e.target.closest('.kh-opt');
    if (!btn) return;
    var val = btn.getAttribute('data-value');
    options.querySelectorAll('.kh-opt').forEach(function(el) { el.classList.remove('selected'); });
    btn.classList.add('selected');
    sessionStorage.setItem('kal_lokasi', val);
    nextBtn.removeAttribute('disabled');
    if (val === 'luarKota') {
      jarakContainer.style.display = 'block';
    } else {
      jarakContainer.style.display = 'none';
    }
  });

  if (jarakInput) {
    jarakInput.addEventListener('input', function() {
      sessionStorage.setItem('kal_jarak', jarakInput.value);
    });
  }

  updateProgress(5, 5);
})();
</script>
