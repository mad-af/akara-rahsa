<div class="kh-step active">
  <h2 class="kh-step-title">Tambahan Layanan</h2>
  <p class="kh-step-desc">Pilih layanan tambahan yang kamu butuhkan (bisa lebih dari satu)</p>
  <div class="kh-options kh-options--multi" id="step4-options">
    <button class="kh-opt kh-opt--multi" data-value="sameDayEdit">
      <span class="kh-opt-label">Same Day Edit</span>
      <span class="kh-opt-desc">Video highlight selesai di hari yang sama</span>
      <span class="kh-opt-price">Rp 750.000</span>
    </button>
    <button class="kh-opt kh-opt--multi" data-value="cinematic">
      <span class="kh-opt-label">Cinematic Video</span>
      <span class="kh-opt-desc">Film-style cinematic video penuh</span>
      <span class="kh-opt-price">Rp 1.000.000</span>
    </button>
    <button class="kh-opt kh-opt--multi" data-value="liveStreaming">
      <span class="kh-opt-label">Live Streaming</span>
      <span class="kh-opt-desc">Siaran langsung akad untuk keluarga jauh</span>
      <span class="kh-opt-price">Rp 500.000</span>
    </button>
    <button class="kh-opt kh-opt--multi" data-value="album">
      <span class="kh-opt-label">Album Cetak</span>
      <span class="kh-opt-desc">Album foto cetak premium</span>
      <span class="kh-opt-price">Rp 400.000</span>
    </button>
  </div>
  <div class="kh-nav">
    <button class="btn-secondary"
      hx-get="/kalkulator/step-3"
      hx-target="#step-container"
      hx-swap="innerHTML">Kembali</button>
    <button class="btn-primary kh-next"
      hx-get="/kalkulator/step-5"
      hx-target="#step-container"
      hx-swap="innerHTML">Lanjut</button>
  </div>
</div>

<script is:inline>
(function() {
  var saved = sessionStorage.getItem('kal_addons');
  var options = document.getElementById('step4-options');

  if (saved) {
    var addons = JSON.parse(saved);
    for (var k in addons) {
      if (addons[k]) {
        var btn = options.querySelector('[data-value="' + k + '"]');
        if (btn) btn.classList.add('selected');
      }
    }
  }

  options.addEventListener('click', function(e) {
    var btn = e.target.closest('.kh-opt');
    if (!btn) return;
    btn.classList.toggle('selected');
    // Save state
    var state = {};
    options.querySelectorAll('.kh-opt').forEach(function(el) {
      state[el.getAttribute('data-value')] = el.classList.contains('selected');
    });
    sessionStorage.setItem('kal_addons', JSON.stringify(state));
  });

  updateProgress(4, 5);
})();
</script>
