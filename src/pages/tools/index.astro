---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Tools — Akara Rahsa" description="Alat bantu perencanaan pernikahan.">
  <main style="max-width: var(--max-width); margin: 0 auto; padding: 6rem var(--gutter) 8rem;">

    <div style="text-align: center; margin-bottom: 4rem;">
      <p class="eyebrow">Alat Bantu</p>
      <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; letter-spacing: -0.02em; color: var(--ink); margin-bottom: 1rem;">
        Tools Pernikahan
      </h1>
      <p style="color: var(--ink-secondary); max-width: 480px; margin: 0 auto; line-height: 1.7;">
        Dua alat sederhana untuk membantu Anda merencanakan perjalanan menuju hari istimewa.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">

      <!-- Card: Budget Calculator -->
      <a href={base + 'tools/budget'} class="tool-card" style="display: block; border: 1px solid rgba(0,0,0,0.08); padding: 2.5rem; text-decoration: none; transition: border-color 0.2s, background 0.2s;">
        <div style="width: 48px; height: 48px; background: rgba(232,180,184,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8B4B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="18" rx="2"/>
            <line x1="2" y1="9" x2="22" y2="9"/>
            <line x1="9" y1="21" x2="9" y2="9"/>
          </svg>
        </div>
        <h2 style="font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem; letter-spacing: -0.01em;">
          Kalkulator Anggaran
        </h2>
        <p style="font-size: 0.875rem; color: var(--ink-secondary); line-height: 1.6; margin-bottom: 1.5rem;">
          Estimasi transparan biaya dokumentasi pernikahan Anda dalam 30 detik. Pilih paket, dapat range harga.
        </p>
        <span style="font-size: 0.8125rem; font-weight: 600; color: #E8B4B8; letter-spacing: 0.05em; text-transform: uppercase;">
          Buka Kalkulator →
        </span>
      </a>

      <!-- Card: Savings Planner -->
      <a href={base + 'tools/simpan'} class="tool-card" style="display: block; border: 1px solid rgba(0,0,0,0.08); padding: 2.5rem; text-decoration: none; transition: border-color 0.2s, background 0.2s;">
        <div style="width: 48px; height: 48px; background: rgba(232,180,184,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8B4B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
        </div>
        <h2 style="font-family: var(--font-display); font-size: 1.375rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem; letter-spacing: -0.01em;">
          Planning Simpanan
        </h2>
        <p style="font-size: 0.875rem; color: var(--ink-secondary); line-height: 1.6; margin-bottom: 1.5rem;">
          Hitung berapa yang perlu Anda tabung tiap bulan, minggu, atau hari untuk mencapai budget pernikahan impian.
        </p>
        <span style="font-size: 0.8125rem; font-weight: 600; color: #E8B4B8; letter-spacing: 0.05em; text-transform: uppercase;">
          Mulai Menabung →
        </span>
      </a>

    </div>
  </main>
</Layout>

<style>
  .tool-card:hover {
    border-color: rgba(0,0,0,0.18);
    background: #FCFCFC;
  }

  @media (max-width: 640px) {
    main > div:nth-child(2) {
      grid-template-columns: 1fr !important;
    }
  }
</style>
