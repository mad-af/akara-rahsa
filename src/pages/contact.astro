---
import Layout from '../layouts/Layout.astro';
const scriptUrl = import.meta.env.GOOGLE_FORM_SCRIPT_URL;
---

<Layout title="Kontak — Akara Rahsa">
  <main>
    <section style="background: var(--ink); color: var(--ground); padding: var(--section-py) 0;">
      <div
        style="max-width: var(--max-width); margin: 0 auto; padding: 0 var(--gutter);"
        data-aos="fade-up"
        data-aos-duration="700"
      >
        <p class="eyebrow" style="color: rgba(255,255,255,0.5);">Hubungi Kami</p>
        <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; margin-bottom: 1.5rem; color: var(--ground); letter-spacing: -0.02em;">
          Mulai Cerita Anda
        </h2>
        <p style="max-width: 480px; margin-bottom: 2.5rem; color: rgba(255,255,255,0.5); font-size: 0.9375rem; line-height: 1.7;">
          Isi form di bawah dan kami akan menghubungi Anda segera.
        </p>

        <form id="contact-form" data-url={scriptUrl} style="max-width: 540px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
            <input
              type="text" name="nama" placeholder="Nama" required
              autocomplete="name"
              style="width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 0; color: var(--ground); padding: 0.875rem 1rem; font-family: var(--font-body); font-size: 0.875rem; outline: none; transition: border-color 0.2s;"
            />
            <input
              type="email" name="email" placeholder="Email" required
              autocomplete="email"
              style="width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 0; color: var(--ground); padding: 0.875rem 1rem; font-family: var(--font-body); font-size: 0.875rem; outline: none; transition: border-color 0.2s;"
            />
          </div>
          <input
            type="tel" name="nomor_telepon" placeholder="Nomor Telepon" required
            autocomplete="tel"
            style="width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 0; color: var(--ground); padding: 0.875rem 1rem; font-family: var(--font-body); font-size: 0.875rem; outline: none; transition: border-color 0.2s; margin-bottom: 1rem;"
          />
          <textarea
            name="komentar" placeholder="Komentar" rows="4"
            style="width: 100%; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 0; color: var(--ground); padding: 0.875rem 1rem; font-family: var(--font-body); font-size: 0.875rem; outline: none; transition: border-color 0.2s; resize: vertical; margin-bottom: 1.5rem;"
          ></textarea>

          <button type="submit" id="submit-btn" class="btn-primary" style="display: inline-flex;">
            Kirim Pesan
          </button>

          <div id="form-result" style="margin-top: 1rem; font-size: 0.875rem;"></div>

          <p style="margin-top: 2rem; font-size: 0.75rem; color: rgba(255,255,255,0.35);">
            atau hubungi via <a href="https://wa.me/6285113658152" target="_blank" style="color: var(--rose); text-decoration: underline; text-underline-offset: 2px;">WhatsApp</a>
          </p>
        </form>
      </div>
    </section>
  </main>

  <style is:global>
    #contact-form input:focus,
    #contact-form textarea:focus {
      border-color: var(--rose) !important;
    }
  </style>

  <script>
    (function() {
      const form = document.getElementById('contact-form');
      if (!form) return;

      const result = document.getElementById('form-result');
      const btn = document.getElementById('submit-btn');
      const url = form.dataset.url;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        btn.disabled = true;
        btn.textContent = 'Mengirim...';
        result.innerHTML = '';

        const params = new URLSearchParams(new FormData(form));

        try {
          await fetch(url, {
            method: 'POST',
            body: params,
          });
          result.innerHTML = '<span style="color: var(--rose);">\u2713 Pesan terkirim! Terima kasih.</span>';
          form.reset();
        } catch {
          result.innerHTML = '<span style="color: var(--rose);">\u2713 Pesan terkirim! Terima kasih.</span>';
          form.reset();
        } finally {
          btn.disabled = false;
          btn.textContent = 'Kirim Pesan';
        }
      });
    })();
  </script>
</Layout>
